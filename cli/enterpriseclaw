#!/usr/bin/env nu

source infra/bootstrap.nu
source infra/cluster.nu
source cluster/connect.nu
source kube-tools/bootstrap.nu
source gitops/bootstrap.nu
source gitops/teardown.nu
source local/main.nu
source slack/main.nu

def "main" [] {
    enterpriseclaw -h
}

#Bootstrap method to accomodate EnterpriseClaw's infraestructure
def --env "main init" [
    --cloud-provider        = "aws"                 #Options: 'aws', 'azure' or 'gcp'
    --cluster-name          = "enterpriseclaw"      #K8s cluster's name

    --secret-provider       = "cloud"               #Secret provider source. Options: 'cloud'. Support is available for: aws/secrets-manager
    --git-provider          = "github"              #Options: 'github', 'azure' or 'gitlab'

    --persistant-state      = false                 #If true, it will create a blob-storage and a NoSQL storage (DocumentDB/DynamoDB) to persist the tofu state
    --gitops-agent          = "argocd"              #Options: 'argocd'
    --gitops-setup          = "push"                #Options: "push", "pull". If 'push', it will directly push to the GitOps repository. If 'pull', it will create a temporary branch and fill a Pull-Request.
] {
    #1. Setup Infra
    if ($secret_provider == "cloud") {  #Every resource can be managed with OpenTofu!
        if ($persistant_state) {
            main cluster bootstrap --cloud-provider=$cloud_provider 
        }
        main cluster setup --cloud-provider=$cloud_provider --cluster-name=$cluster_name --git-secret-name="($git_provider)-creds" --webhook-secret-name="($git_provider)-webhook-creds"
    }

    #2. Connect to the cluster
    main cluster connect --cloud-provider=$cloud_provider --region=$env.region --cluster-name=$"($cluster_name)-cluster"

    #3. GitOps and Kube-tools preconditioning (also registers the agentic platform ŌĆö kagent trio +
    #   agentic CRs ŌĆö and the Session-Broker into the app-of-apps, exposes broker+Keycloak on the
    #   shared platform ALB, and writes the tenant Keycloak/broker hostname ConfigMaps)
    main kube-tools bootstrap --git-provider=$git_provider --gitops-setup=$gitops_setup --cloud-provider=$cloud_provider

    #4. GitOps initializer
    main init gitops --gitops-agent=$gitops_agent --cloud-provider=$cloud_provider

}

#Destroy all the created and configured infrastructure of the project! (Ideal for ephemeral environments)
def --env "main destroy" [
    --cluster-name          = "enterpriseclaw"      #K8s cluster's name
    --cloud-provider        = "aws"                 #Options: 'aws', 'azure' or 'gcp'
    --local-testing         = false                 #If you're doing local testing, you might want to delete the 'bootstrap' tofu configuration
    --gitops-agent          = "argocd"              #Options: 'argocd'
] {
    #1. Cluster connection
    main cluster connect --cloud-provider=$cloud_provider --region=$env.region --cluster-name=$"($cluster_name)-cluster"

    #2. Drain the load balancers (ALB/NLBs/Classic-ELB) + their managed SGs and DNS, then wait until
    #   AWS has actually released them ŌĆö so `tofu destroy` is not blocked by DependencyViolation on
    #   the VPC nor by ResourceInUse on the ACM cert. (Replaces the old blind `sleep 120sec`, which
    #   raced the controller teardown; the wait now lives inside `main teardown gitops`.)
    main teardown gitops --gitops-agent=$gitops_agent --cloud-provider=$cloud_provider --cluster-name=$cluster_name

    #3. Delete Image Registry (REVIEW)
    #containers destroy all --path=$image_path_base

    #4. Destroy all infrastructure
    main destroy infra --cloud-provider=$cloud_provider --cluster-name=$cluster_name
}

def "main destroy infra" [
    --cloud-provider        = "aws"                 #Options: 'aws', 'azure' or 'gcp'
    --cluster-name          = "enterpriseclaw"      #K8s cluster's name
    --local-testing         = false                 #If you're doing local testing, you might want to delete the 'bootstrap' tofu configuration
] {
    #1. Teardown infrastructure
    main cluster teardown --cloud-provider=$cloud_provider

    #2. Sweep up the EBS volumes the CSI driver provisioned from the platform's PVCs
    #   (keycloak/redis/postgres/dapr/kagent). Terraform never tracked them, so they survive
    #   `tofu destroy` orphaned in `available` state ŌĆö delete them so nothing lingers/costs.
    if ($cloud_provider == "aws") {
        cleanup-orphaned-ebs --cluster-name=$"($cluster_name)-cluster"
    }

    #3. Delete persistant storage (for local testing)
    if ($local_testing) {
        main cluster bootstrap destroy --cloud-provider=$cloud_provider
    }
}


