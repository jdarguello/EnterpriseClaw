{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
    "packages": [
        "nushell@0.112.2",
        "opentofu@1.11.6",
        "podman@5.8.2",
        "kubectl@1.36.0",
        "kubernetes-helm@3.20.2",
        "argo@3.6.3",
        "argo-workflows@3.6.10",
        "awscli2@2.28.1",
        "crossplane-cli@2.0.2",
        "git@2.53.0",
        "gh@2.92.0",
        "curl@8.17.0"
    ],
    "env_from": ".env",
    "shell": {
      "init_hook": [
        "chmod +x enterpriseclaw",
        "export PATH=$PATH:$PWD",
        "nu"
      ]
    }
}